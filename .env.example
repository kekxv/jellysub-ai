# JellySub-AI 环境变量配置
# 复制此文件为 .env 并填写实际值

# --- 管理后台认证 ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password

# TOTP 共享密钥（使用 pyotp.random_base32() 生成，或在 Authenticator App 中配置）
# 留空则跳过 TOTP 验证
TOTP_SECRET=

# --- Webhook 签名校验 ---
# Jellyfin Webhook 中设置的共享密钥，用于验证请求来源
WEBHOOK_SECRET=

# --- Session 签名密钥 ---
# 留空则自动生成（重启后 session 失效）
SESSION_SECRET=

# --- 模型下载源 ---
# huggingface (默认) | modelscope (使用 ModelScope 下载，自动配置 HF_ENDPOINT=hf-mirror.com)
# 设置 MODEL_SOURCE=modelscope 时，会自动从 modelscope.cn 下载模型到 ./model_cache
MODEL_SOURCE=
